# Copy to .env and fill in your values

# REQUIRED — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# LLM model (default is claude-opus-4-6)
LLM_MODEL=claude-opus-4-6

# Database (override for Docker: postgresql+asyncpg://tutor:tutor@db:5432/tutor)
DATABASE_URL=postgresql+asyncpg://tutor:tutor@localhost:5432/tutor

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# MinIO / S3
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=tutor-documents
STORAGE_USE_SSL=false

# Auth (Clerk — leave blank for dev)
CLERK_JWT_ISSUER=

# Ingestion limits
MAX_FILE_SIZE_MB=50

# Debug
DEBUG=false
